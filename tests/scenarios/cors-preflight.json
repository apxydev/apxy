{
  "name": "cors-preflight",
  "description": "Agent diagnoses CORS preflight failures where OPTIONS response lacks required headers",

  "setup": {
    "fixture_server": {
      "port": 9091,
      "routes": [
        { "path": "/api/data", "method": "OPTIONS", "status": 200, "body": "" },
        { "path": "/api/data", "method": "GET", "status": 200, "body": "{\"data\":[1,2,3]}" }
      ]
    },
    "apxy": { "port": 8081 },
    "seed_traffic": [
      { "method": "OPTIONS", "url": "http://127.0.0.1:9091/api/data", "repeat": 2, "headers": {"Origin": "http://localhost:3000", "Access-Control-Request-Method": "GET"} },
      { "method": "GET", "url": "http://127.0.0.1:9091/api/data", "repeat": 2 }
    ]
  },

  "prompt": "My frontend at localhost:3000 is getting CORS errors when calling the API at localhost:9091/api/data. The proxy is running on port 8081 and traffic has been captured. Can you help me figure out what's wrong using apxy?",

  "checkpoints": [
    {
      "id": "search-options",
      "description": "Agent searches for OPTIONS/preflight requests",
      "match": { "command_contains_any": ["apxy logs search", "apxy logs list"] }
    },
    {
      "id": "inspect-preflight",
      "description": "Agent inspects the preflight response",
      "match": { "command_contains": "apxy logs show" },
      "after": "search-options"
    }
  ],

  "outcome": {
    "transcript_contains_any": ["Access-Control-Allow-Origin", "CORS", "preflight", "OPTIONS"],
    "description": "Agent identifies missing CORS headers in the preflight response"
  }
}
